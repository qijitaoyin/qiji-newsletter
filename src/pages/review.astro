---
import "../styles/global.css";
import { pathFor } from "../utils/paths";
import { reviewItems, reviewIssueIds, reviewSummary } from "../data/review";
import {
  wordNormalizeIssueIds,
  wordNormalizeItems,
  wordNormalizeSummary
} from "../data/wordNormalizeReview";
import { reviewIssueArticles, reviewIssueArchive } from "../data/articles";

const reviewPublishWebhookUrl = import.meta.env.PUBLIC_REVIEW_PUBLISH_WEBHOOK_URL || "";

const statusLabels: Record<string, string> = {
  error: "不可上架",
  "needs-review": "需人工校對",
  approved: "已核准"
};

const typeLabels: Record<string, string> = {
  "template-invalid": "模板格式錯誤",
  "legacy-template-missing": "舊稿格式",
  "missing-author": "作者缺漏",
  "content-warning": "內容警示",
  "unknown-category": "分類待確認",
  "possible-duplicate": "疑似重複"
};

const wordStatusLabels: Record<string, string> = {
  error: "不可處理",
  normalize: "可自動標準化",
  normalized: "已標準化",
  review: "需人工確認",
  skipped: "已是標準格式"
};

const reasonLabels: Record<string, string> = {
  "already-standard": "這篇已經符合標準模板。",
  "table-of-contents": "這是目錄檔，系統會自動忽略，不列入文章上架。",
  "empty-document": "這個 Word 檔沒有可讀取的正文內容。",
  "legacy-heading-suggestion": "系統已依舊稿前幾行推測分類、標題、作者與日期，請確認是否正確。",
  "needs-confirmation": "系統已提出推測結果，但仍需人工確認後才建議正式上架。",
  "unsupported-legacy-structure": "舊稿格式無法穩定判讀，需人工開啟 Word 修正或補成標準模板。"
};

const issueGroups = reviewIssueIds.map((issueId) => ({
  issueId,
  items: reviewItems.filter((item) => item.issueId === issueId)
}));

const wordReviewGroups = wordNormalizeIssueIds
  .map((issueId) => ({
    issueId,
    items: wordNormalizeItems.filter(
      (item) => item.issueId === issueId && (item.status === "error" || item.status === "review")
    )
  }))
  .filter((group) => group.items.length > 0);

const latestReviewArticles = reviewIssueArticles;
const latestReviewArchive = reviewIssueArchive;
const normalizeCategory = (category: string) => {
  if (category.startsWith("如是我")) return "如是我聞";
  if (category === "同頻共振時") return "導引專欄";
  return category;
};
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" href={pathFor("/assets/qiji-logo.png")} type="image/png" />
    <title>上架校對 - 氣機導引電子報</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={pathFor("/")} aria-label="氣機導引電子報">
        <span class="brand-mark"><img src={pathFor("/assets/qiji-logo.png")} alt="" /></span>
        <span class="brand-text">
          <strong>氣機導引電子報</strong>
          <small>Import Review</small>
        </span>
      </a>

      <div class="header-actions">
        <nav class="top-nav review-local-nav" aria-label="校對頁導覽">
          <a href="/review/">校對工作台</a>
        </nav>
      </div>
    </header>

    <main class="review-page">
      <section class="review-hero">
        <p class="meta-line">
          <span>Google Drive 匯入</span>
          <span>Word 標準化</span>
          <span>人工校對確認</span>
        </p>
        <h1>上架校對</h1>
        <p>
          這裡列出最新一期校對、上架人員待辦與舊稿整理。校對意見會先集中成待辦；上架人員確認修正完成後，再產生發布核准檔。
          金句與分類標籤屬於網站附加資料，不會寫回 Word 正文。
        </p>
      </section>

      <div class="review-mode-tabs" role="tablist" aria-label="校對模式">
        <button type="button" class="is-active" data-review-mode-tab="current">最新一期校對</button>
        <button type="button" data-review-mode-tab="legacy">舊稿整理</button>
      </div>

      <div class="review-mode-panel is-active" data-review-mode-panel="current">
      <section class="review-workflow review-current-workspace" aria-label="最新一期校對工作台">
        <div>
          <p class="review-kicker">最新一期校對</p>
          <h2>{latestReviewArchive?.issueNumber ?? "最新一期"} / {latestReviewArchive?.date ?? ""}</h2>
          <p>
          校對者可在同一篇文章內切換電腦版與手機版預覽，直接留下修正意見與截圖。上架人員處理完每一則待辦後，再從統計區送出正式發布。
          </p>
        </div>
        <div class="review-summary review-current-summary" aria-label="最新一期校對統計">
          <article class="review-stat is-review">
            <strong>{latestReviewArticles.length}</strong>
            <span>本期待校對文章</span>
          </article>
          <article class="review-stat">
            <strong data-report-count>0</strong>
            <span>已回報修正意見</span>
          </article>
          <article class="review-stat is-approved">
            <strong data-report-done-count>0</strong>
            <span>已處理待辦</span>
          </article>
          <div class="review-summary-actions">
            <span data-publish-status>尚未產生發布確認。</span>
            <button type="button" data-submit-reimport>{"\u91cd\u65b0\u532f\u5165\u6700\u65b0 Word"}</button>
            <button type="button" data-submit-publish>送出正式發布</button>
            <pre data-publish-preview hidden>{`{
  "status": "pending",
  "reports": [],
  "metadataOverrides": {
    "quotes": {},
    "tags": {}
  }
}`}</pre>
          </div>
          <section class="review-task-board review-summary-tasks" aria-label="上架人員待辦">
            <div class="review-task-board-head">
              <div>
                <p class="review-kicker">上架人員待辦</p>
                <h2>修正意見集中區</h2>
              </div>
              <button type="button" data-clear-reports>清空回報</button>
            </div>
            <div class="review-task-list" data-report-board>
              <p class="review-empty-state">目前沒有修正意見。</p>
            </div>
          </section>
        </div>
      </section>

      <section class="review-live-workspace" aria-label="正式版面校對" data-live-review>
        <div class="review-live-panel">
          <div class="review-live-controls">
            <label>
              <span>文章</span>
              <select name="articleSlug" data-review-article-select>
                {latestReviewArticles.map((article) => (
                  <option
                    value={article.slug}
                    data-title={article.title}
                    data-category={article.category}
                    data-author={article.author}
                    data-quote={article.aiQuote ?? ""}
                    data-url={pathFor(`/articles/${article.slug}/`)}
                    data-frame-url={pathFor(`/articles/${article.slug}/?reviewFrame=1`)}
                  >
                    {article.title}
                  </option>
                ))}
              </select>
            </label>
            <a data-live-open-link href={pathFor(`/articles/${latestReviewArticles[0]?.slug ?? ""}/`)} target="_blank" rel="noreferrer">
              開啟正式頁
            </a>
          </div>

          <div class="review-live-tabs" role="tablist" aria-label="正式頁預覽版面">
            <button type="button" class="is-active" data-live-viewport-tab="desktop">電腦版</button>
            <button type="button" data-live-viewport-tab="mobile">手機版</button>
          </div>

          <div class="review-live-preview is-active" data-live-viewport-panel="desktop">
            <iframe
              title="電腦版正式文章預覽"
              data-live-frame="desktop"
              scrolling="no"
              src={pathFor(`/articles/${latestReviewArticles[0]?.slug ?? ""}/?reviewFrame=1`)}
            ></iframe>
          </div>
          <div class="review-live-preview review-live-preview-mobile" data-live-viewport-panel="mobile">
            <iframe
              title="手機版正式文章預覽"
              data-live-frame="mobile"
              scrolling="no"
              src={pathFor(`/articles/${latestReviewArticles[0]?.slug ?? ""}/?reviewFrame=1`)}
            ></iframe>
          </div>

          <div class="review-live-feedback" aria-label="校對回報">
            <form class="review-report-form review-live-report-form" data-report-form>
              <div class="review-current-article" data-current-article-label>
                <div>
                  <span>分類</span>
                  <strong data-current-article-category>{latestReviewArticles[0]?.category ?? ""}</strong>
                </div>
                <div>
                  <span>標題</span>
                  <strong data-current-article-title>{latestReviewArticles[0]?.title ?? ""}</strong>
                </div>
                <div>
                  <span>作者</span>
                  <strong data-current-article-author>{latestReviewArticles[0]?.author ?? ""}</strong>
                </div>
                <div>
                  <span>建議金句</span>
                  <strong data-current-article-quote>{latestReviewArticles[0]?.aiQuote ?? ""}</strong>
                </div>
              </div>
              <label class="review-report-wide">
                <span>修正意見</span>
                <textarea name="comment" rows="1" required placeholder="直接寫要修改的地方；可先貼截圖，再補文字。"></textarea>
              </label>
              <div class="review-screenshot-paste" tabindex="0" data-screenshot-paste>
                <strong>貼上截圖</strong>
                <span>點這裡後按 Ctrl+V，或在意見欄直接貼上圖片</span>
                <div data-screenshot-preview></div>
              </div>
              <div class="review-report-actions">
                <button type="submit">送出修正意見</button>
                <span data-report-result></span>
              </div>
            </form>
            <div class="review-article-report-list" data-live-article-report-list>
              <p class="review-empty-state">這篇目前沒有回報。</p>
            </div>
          </div>
        </div>
      </section>

      </div>

      <div class="review-mode-panel" data-review-mode-panel="legacy">
      <section class="review-approval-panel" aria-label="核准結果">
        <div>
          <h2>核准結果</h2>
          <p>
            按下確認後，該篇會加入下方 JSON。校對完成後請儲存或下載
            <code>review-approvals.json</code>，放在專案根目錄，再重新執行匯入與建置。
          </p>
        </div>
        <div class="review-approval-actions">
          <strong><span data-approval-count>0</span> 篇已確認</strong>
          <button type="button" data-save-approvals>儲存核准檔</button>
          <button type="button" data-download-approvals>下載 JSON</button>
          <button type="button" data-copy-approvals>複製 JSON</button>
          <button type="button" data-clear-approvals>清空</button>
        </div>
        <pre data-approval-preview>{`{
  "approvals": []
}`}</pre>
        <div class="review-fix-list" data-fix-list hidden>
          <h3>待修正 Word 清單</h3>
          <p>以下是你已標記「需要修正 Word」的文章，之後依照檔案路徑回 Word 修改即可。</p>
          <ul data-fix-list-items></ul>
        </div>
        <div class="review-processed-list" data-processed-list hidden>
          <h3>已處理項目</h3>
          <p>如果剛剛按錯，可以在這裡退回原卡片重新校對或局部修正。</p>
          <ul data-processed-list-items></ul>
        </div>
      </section>

      <section class="review-workflow" aria-label="Word 標準化狀態">
        <h2>Word 標準化校對</h2>
        <p>
          這一區是舊稿整理用。系統會顯示它從 Word 前幾行推測出的分類、標題、作者、日期與首段。
          如果判斷正確，可以先確認；如果不正確，請回 Word 檔改成標準模板後重新匯入。
        </p>
        <div class="review-summary" aria-label="Word 標準化統計">
          <article class="review-stat is-error">
            <strong>{wordNormalizeSummary.error}</strong>
            <span>不可處理</span>
          </article>
          <article class="review-stat is-review">
            <strong>{wordNormalizeSummary.review}</strong>
            <span>需人工確認</span>
          </article>
          <article class="review-stat is-approved">
            <strong>{wordNormalizeSummary.skipped}</strong>
            <span>已是標準格式</span>
          </article>
          <article class="review-stat">
            <strong>{wordNormalizeSummary.total}</strong>
            <span>全部 Word</span>
          </article>
        </div>
      </section>

      <section class="review-list" aria-label="Word 標準化校對清單">
        {wordReviewGroups.map((group) => (
          <section class="review-issue" id={`word-${group.issueId}`}>
            <header>
              <h2>{group.issueId}</h2>
              <span>{group.items.length} 篇需處理</span>
            </header>

            <div class="review-items">
              {group.items.map((item) => (
                <article
                  class={`review-card status-${item.status === "error" ? "error" : "needs-review"}`}
                  data-word-review-card
                  data-approval-id={`word::${item.file}`}
                  data-source-modified=""
                  data-issue-id={item.issueId}
                  data-title={item.title || item.file.split(/[\\/]/).pop()}
                  data-category={item.category || ""}
                  data-author={item.author || ""}
                  data-date={item.date || item.issueId}
                  data-file={item.file}
                  data-kind="word-normalize"
                >
                  <div class="review-card-main">
                    <div class="review-card-head">
                      <div>
                        <p class="review-status">{wordStatusLabels[item.status] ?? item.status}</p>
                        <h3>{item.title || item.file.split(/[\\/]/).pop()}</h3>
                      </div>
                      {item.status !== "error" && (
                        <div class="review-actions review-actions-inline">
                          <button type="button" data-approve-item>確認可上架</button>
                          <button type="button" data-edit-item>局部修正</button>
                          <button type="button" data-ignore-item>不需上架／忽略</button>
                          <button type="button" data-fix-item>需要修正 Word</button>
                        </div>
                      )}
                    </div>
                    {item.status !== "error" && (
                      <form class="review-inline-edit" data-inline-edit hidden>
                        <label>
                          <span>文章分類</span>
                          <input name="category" value={item.category || ""} />
                        </label>
                        <label>
                          <span>文章標題</span>
                          <input name="title" value={item.title || ""} />
                        </label>
                        <label>
                          <span>作者</span>
                          <input name="author" value={item.author || ""} />
                        </label>
                        <label>
                          <span>日期</span>
                          <input name="date" value={item.date || item.issueId} />
                        </label>
                        <label class="review-inline-edit-note">
                          <span>備註</span>
                          <textarea name="note" rows="2" placeholder="例如：只補作者，其他欄位正確"></textarea>
                        </label>
                        <div>
                          <button type="submit">套用修正並上架</button>
                          <button type="button" data-cancel-edit>取消</button>
                        </div>
                      </form>
                    )}
                    <div class="review-judgement">
                      <h4>系統判斷結果</h4>
                      <ol>
                        <li><strong>文章分類：</strong>{item.category || "分類待判斷"}</li>
                        <li><strong>文章標題：</strong>{item.title || "標題待判斷"}</li>
                        <li><strong>作者：</strong>{item.author || "作者待判斷"}</li>
                        <li><strong>日期：</strong>{item.date || item.issueId}</li>
                      </ol>
                    </div>
                    {item.preview && <p class="review-excerpt">{item.preview}</p>}
                    {item.firstLines && item.firstLines.length > 0 && (
                      <div class="review-lines-block">
                        <h4>原始 Word 內容參考</h4>
                        <p>以下是系統抓到的原始段落，供你比對上方判斷是否正確。</p>
                        <ol class="review-lines">
                          {item.firstLines.map((line) => <li>{line}</li>)}
                        </ol>
                      </div>
                    )}
                    <p class="review-file">{item.file}</p>
                  </div>

                  <div class="review-messages">
                    <p class={`review-message severity-${item.status === "error" ? "error" : "warning"}`}>
                      <strong>{reasonLabels[item.reason || item.rule || ""] ?? item.reason ?? item.rule ?? "需確認"}</strong>
                      <span>{reasonLabels[item.rule || ""] ?? "請確認上方系統判斷是否可接受。"}</span>
                    </p>
                  </div>

                  {item.status !== "error" && <div class="review-actions"></div>}
                </article>
              ))}
            </div>
          </section>
        ))}
      </section>

      <section class="review-workflow" aria-label="匯入校對狀態">
        <h2>正式匯入校對</h2>
        <p>
          這一區是實際上架流程的校對清單。按下「確認可上架」後，文章會被寫入核准 JSON；重新匯入後即可由系統視為校對通過。
        </p>
        <div class="review-summary" aria-label="匯入校對統計">
          <article class="review-stat is-error">
            <strong>{reviewSummary.error}</strong>
            <span>不可上架</span>
          </article>
          <article class="review-stat is-review">
            <strong>{reviewSummary.needsReview}</strong>
            <span>需人工校對</span>
          </article>
          <article class="review-stat is-approved">
            <strong>{reviewSummary.approved}</strong>
            <span>已核准</span>
          </article>
          <article class="review-stat">
            <strong>{reviewSummary.total}</strong>
            <span>全部項目</span>
          </article>
        </div>
      </section>

      <section class="review-list" aria-label="匯入校對清單">
        {issueGroups.map((group) => (
          <section class="review-issue" id={`issue-${group.issueId}`}>
            <header>
              <h2>{group.issueId}</h2>
              <span>{group.items.length} 篇</span>
            </header>

            <div class="review-items">
              {group.items.map((item) => (
                <article
                  class={`review-card status-${item.status}`}
                  data-import-review-card
                  data-approval-id={item.id}
                  data-source-modified={item.sourceModified}
                  data-issue-id={item.issueId}
                  data-title={item.title || item.sourceId || "未命名文章"}
                  data-category={item.category || ""}
                  data-author={item.author || ""}
                  data-date={item.date || item.issueId}
                  data-file={item.file}
                  data-kind="import"
                >
                  <div class="review-card-main">
                    <p class="review-status">{statusLabels[item.status] ?? item.status}</p>
                    <h3>{item.title || item.sourceId || "未命名文章"}</h3>
                    <p class="review-meta">
                      <span>{item.category || "分類待判斷"}</span>
                      <span>{item.author || "作者待判斷"}</span>
                      <span>{item.date || item.issueId}</span>
                    </p>
                    <div class="review-actions review-actions-inline">
                      {item.slug && <a href={pathFor(`/articles/${item.slug}/`)}>閱讀預覽</a>}
                      {item.status !== "error" && <button type="button" data-approve-item>確認可上架</button>}
                      {item.status !== "error" && <button type="button" data-edit-item>局部修正</button>}
                      <button type="button" data-ignore-item>不需上架／忽略</button>
                    </div>
                    {item.status !== "error" && (
                      <form class="review-inline-edit" data-inline-edit hidden>
                        <label>
                          <span>文章分類</span>
                          <input name="category" value={item.category || ""} />
                        </label>
                        <label>
                          <span>文章標題</span>
                          <input name="title" value={item.title || item.sourceId || ""} />
                        </label>
                        <label>
                          <span>作者</span>
                          <input name="author" value={item.author || ""} />
                        </label>
                        <label>
                          <span>日期</span>
                          <input name="date" value={item.date || item.issueId} />
                        </label>
                        <label class="review-inline-edit-note">
                          <span>備註</span>
                          <textarea name="note" rows="2" placeholder="例如：只補作者，其他欄位正確"></textarea>
                        </label>
                        <div>
                          <button type="submit">套用修正並上架</button>
                          <button type="button" data-cancel-edit>取消</button>
                        </div>
                      </form>
                    )}
                    {item.excerpt && <p class="review-excerpt">{item.excerpt}</p>}
                    <p class="review-file">{item.file}</p>
                  </div>

                  {item.image && (
                    <figure class="review-thumb">
                      <img src={item.image} alt="" loading="lazy" />
                    </figure>
                  )}

                  <div class="review-messages">
                    {item.messages.map((message) => (
                      <p class={`review-message severity-${message.severity}`}>
                        <strong>{typeLabels[message.type] ?? message.type}</strong>
                        <span>{message.message}</span>
                      </p>
                    ))}
                  </div>

                  <div class="review-actions">
                    <code>{item.id}</code>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </section>
      </div>
    </main>

    <script define:vars={{
      publishWebhookUrl: reviewPublishWebhookUrl,
      reviewArticleIndex: latestReviewArticles.map((article) => ({
        slug: article.slug,
        title: article.title,
        category: normalizeCategory(article.category)
      }))
    }}>
      const storageKey = "qiji-review-approvals";
      const countNode = document.querySelector("[data-approval-count]");
      const previewNode = document.querySelector("[data-approval-preview]");
      const fixListNode = document.querySelector("[data-fix-list]");
      const fixListItemsNode = document.querySelector("[data-fix-list-items]");
      const processedListNode = document.querySelector("[data-processed-list]");
      const processedListItemsNode = document.querySelector("[data-processed-list-items]");
      const saveButton = document.querySelector("[data-save-approvals]");
      const downloadButton = document.querySelector("[data-download-approvals]");
      const copyButton = document.querySelector("[data-copy-approvals]");
      const clearButton = document.querySelector("[data-clear-approvals]");
      const reportStorageKey = "qiji-review-reports-v1";
      const reportBoard = document.querySelector("[data-report-board]");
      const reportCountNode = document.querySelector("[data-report-count]");
      const reportDoneCountNode = document.querySelector("[data-report-done-count]");
      const clearReportsButton = document.querySelector("[data-clear-reports]");
      const publishPreviewNode = document.querySelector("[data-publish-preview]");
      const publishStatusNode = document.querySelector("[data-publish-status]");
      const submitReimportButton = document.querySelector("[data-submit-reimport]");
      const submitPublishButton = document.querySelector("[data-submit-publish]");
      const liveArticleSelect = document.querySelector("[data-review-article-select]");
      const currentArticleLabel = document.querySelector("[data-current-article-label]");
      const liveOpenLink = document.querySelector("[data-live-open-link]");
      const liveFrames = Array.from(document.querySelectorAll("[data-live-frame]"));
      const liveViewportTabs = Array.from(document.querySelectorAll("[data-live-viewport-tab]"));
      const liveViewportPanels = Array.from(document.querySelectorAll("[data-live-viewport-panel]"));
      const liveReportLists = Array.from(document.querySelectorAll("[data-live-article-report-list]"));
      const deployWorkflowUrl =
        "https://github.com/qijitaoyin/qiji-newsletter/actions/workflows/deploy-github-pages.yml";
      const deployWorkflowRunsApiUrl =
        "https://api.github.com/repos/qijitaoyin/qiji-newsletter/actions/workflows/deploy-github-pages.yml/runs?event=workflow_dispatch&branch=main&per_page=10";
      const sleep = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));

      const workflowStatusLabel = (run) => {
        if (!run) return "\u7b49\u5f85 GitHub Actions \u5efa\u7acb\u4f5c\u696d...";
        if (run.status === "queued") return "\u5df2\u6392\u5165\u5efa\u7f6e\u968a\u5217...";
        if (run.status === "in_progress") return "\u6b63\u5728\u540c\u6b65 Word \u4e26\u91cd\u5efa\u7db2\u7ad9...";
        if (run.status === "completed" && run.conclusion === "success") {
          return "\u91cd\u65b0\u532f\u5165\u5df2\u5b8c\u6210\uff0c\u53ef\u4ee5\u91cd\u65b0\u6574\u7406\u672c\u9801\u6aa2\u67e5\u9810\u89bd\u3002";
        }
        if (run.status === "completed") return "\u91cd\u65b0\u532f\u5165\u6c92\u6709\u6210\u529f\uff0c\u8acb\u5230 GitHub Actions \u67e5\u770b\u539f\u56e0\u3002";
        return "\u6b63\u5728\u67e5\u8a62\u532f\u5165\u9032\u5ea6...";
      };

      const fetchWorkflowRuns = async () => {
        const response = await fetch(deployWorkflowRunsApiUrl, {
          headers: { Accept: "application/vnd.github+json" },
          cache: "no-store"
        });
        if (!response.ok) throw new Error(`GitHub Actions API ${response.status}`);
        const data = await response.json();
        return Array.isArray(data.workflow_runs) ? data.workflow_runs : [];
      };

      const latestWorkflowRun = async () => {
        const runs = await fetchWorkflowRuns();
        return runs[0] || null;
      };

      const workflowRunAfter = async ({ previousRunId, startedAt }) => {
        const runs = await fetchWorkflowRuns();
        const startedTime = startedAt.getTime() - 5 * 60000;
        return (
          runs.find((run) => {
            const isNewId = previousRunId ? String(run.id) !== String(previousRunId) : true;
            const isRecent = new Date(run.created_at).getTime() >= startedTime;
            return isNewId && isRecent;
          }) || null
        );
      };

      const syncDriveStepWasSkipped = async (run) => {
        if (!run?.jobs_url) return false;
        const response = await fetch(run.jobs_url, {
          headers: { Accept: "application/vnd.github+json" },
          cache: "no-store"
        });
        if (!response.ok) return false;
        const data = await response.json();
        const jobs = Array.isArray(data.jobs) ? data.jobs : [];
        return jobs.some((job) =>
          (Array.isArray(job.steps) ? job.steps : []).some(
            (step) =>
              step.name === "Sync Google Drive source" &&
              step.conclusion === "skipped"
          )
        );
      };

      const pollReimportWorkflow = async ({ previousRunId, startedAt }) => {
        let lastRun = null;
        for (let index = 0; index < 45; index += 1) {
          await sleep(index === 0 ? 6000 : 8000);
          lastRun = await workflowRunAfter({ previousRunId, startedAt });
          if (publishStatusNode) {
            const runLink = lastRun?.html_url || deployWorkflowUrl;
            publishStatusNode.innerHTML = `<span class="review-progress-dot"></span>${workflowStatusLabel(lastRun)} <a href="${runLink}" target="_blank" rel="noreferrer">\u67e5\u770b\u9032\u5ea6</a>`;
          }
          if (lastRun?.status === "completed") return lastRun;
        }
        return lastRun;
      };

      const readReports = () => {
        try {
          const parsed = JSON.parse(window.localStorage.getItem(reportStorageKey) || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      };

      const writeReports = (reports) => {
        window.localStorage.setItem(reportStorageKey, JSON.stringify(reports));
      };

      const escapeHtml = (value = "") =>
        String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");

      const selectedArticleOption = (select = liveArticleSelect) =>
        select?.selectedOptions?.[0] || null;

      const articleFromOption = (option) => ({
        slug: option?.value || "",
        title: option?.dataset.title || option?.textContent?.trim() || "",
        category: option?.dataset.category || "",
        author: option?.dataset.author || "",
        quote: option?.dataset.quote || "",
        url: option?.dataset.url || "",
        frameUrl: option?.dataset.frameUrl || option?.dataset.url || ""
      });

      let currentArticle = articleFromOption(selectedArticleOption());

      const renderCurrentArticleLabel = (article = currentArticle) => {
        if (!currentArticleLabel) return;
        currentArticleLabel.dataset.articleSlug = article?.slug || "";
        const categoryNode = currentArticleLabel.querySelector("[data-current-article-category]");
        const titleNode = currentArticleLabel.querySelector("[data-current-article-title]");
        const authorNode = currentArticleLabel.querySelector("[data-current-article-author]");
        const quoteNode = currentArticleLabel.querySelector("[data-current-article-quote]");
        if (categoryNode) categoryNode.textContent = article?.category || "";
        if (titleNode) titleNode.textContent = article?.title || "";
        if (authorNode) authorNode.textContent = article?.author || "";
        if (quoteNode) quoteNode.textContent = article?.quote || "";
      };

      const slugFromArticleUrl = (value = "") => {
        try {
          const url = new URL(value, window.location.href);
          const path = url.pathname.replace(/\/+$/, "");
          return path.match(/\/articles\/([^/]+)$/)?.[1] || "";
        } catch {
          return "";
        }
      };

      const syncSelectedArticle = (slug) => {
        if (!slug) return null;
        if (liveArticleSelect && liveArticleSelect.value !== slug) liveArticleSelect.value = slug;
        const article = articleFromOption(selectedArticleOption(liveArticleSelect));
        currentArticle = article;
        renderCurrentArticleLabel(article);
        if (liveOpenLink && article.url) liveOpenLink.setAttribute("href", article.url);
        return article;
      };

      const resizeLiveFrame = (frame) => {
        if (!frame) return;
        try {
          const doc = frame.contentDocument || frame.contentWindow?.document;
          if (!doc) return;
          const scrollTop = frame.contentWindow?.scrollY || doc.documentElement?.scrollTop || doc.body?.scrollTop || 0;
          const content = doc.querySelector(".article-page") || doc.querySelector("main") || doc.body;
          const contentBottom = content ? content.getBoundingClientRect().bottom + scrollTop : 0;
          const fallbackHeight = Math.max(
            doc.documentElement?.scrollHeight || 0,
            doc.body?.scrollHeight || 0
          );
          const height = Math.ceil(contentBottom || fallbackHeight);
          if (height > 0) frame.style.height = `${height + 2}px`;
        } catch {
          // Same-origin review frames should resize; ignore browser edge cases.
        }
      };

      const resizeLiveFrames = () => {
        liveFrames.forEach(resizeLiveFrame);
      };

      const syncLiveArticle = (slug) => {
        if (!slug) return;
        const article = syncSelectedArticle(slug);
        if (!article) return;
        liveFrames.forEach((frame) => {
          if (article.frameUrl && frame.getAttribute("src") !== article.frameUrl) {
            frame.setAttribute("src", article.frameUrl);
          } else {
            resizeLiveFrame(frame);
          }
        });
        renderReports();
      };

      const syncLiveViewport = (viewport) => {
        liveViewportTabs.forEach((tab) => {
          tab.classList.toggle("is-active", tab.getAttribute("data-live-viewport-tab") === viewport);
        });
        liveViewportPanels.forEach((panel) => {
          panel.classList.toggle("is-active", panel.getAttribute("data-live-viewport-panel") === viewport);
        });
      };

      const reportStatusLabel = (status) => {
        if (status === "fixed") return "Word 已修，待重新匯入確認";
        if (status === "metadata") return "網站資料已採用，待發布";
        if (status === "done") return "確認完成";
        return "待處理";
      };

      const reportPrimaryAction = (status) => {
        if (status === "fixed") return "重新匯入後確認無誤";
        if (status === "metadata") return "確認可發布";
        if (status === "done") return "改回待處理";
        return "標記 Word 已修";
      };

      const extractMetadataQuote = (comment = "") => {
        const text = String(comment).trim();
        const explicit = text.match(/(?:^|\n)\s*(?:金句|重點金句|網站金句|採用金句|指定金句)[：:\s]+(.+)$/u);
        if (explicit?.[1]?.trim()) return explicit[1].trim();
        return "";
      };

      const buildPublishPayload = () => {
        const reports = readReports();
        const completedReports = reports.filter((report) =>
          ["done", "metadata"].includes(report.status)
        );
        const openReports = reports.filter((report) =>
          !["done", "metadata"].includes(report.status)
        );
        const quotes = {};
        const tags = {};

        completedReports.forEach((report) => {
          if (report.metadataQuote) {
            quotes[report.articleSlug] = report.metadataQuote;
          }
          if (Array.isArray(report.metadataTags) && report.metadataTags.length) {
            tags[report.articleSlug] = report.metadataTags;
          }
        });

        return {
          status: openReports.length ? "has-open-tasks" : "ready-to-publish",
          generatedAt: new Date().toISOString(),
          issueId: "latest",
          reports: completedReports,
          openReports,
          metadataOverrides: {
            quotes,
            tags
          }
        };
      };

      const reportCardHtml = (report, compact = false, showArticleTitle = true) => {
        const quoteCandidate = extractMetadataQuote(report.comment);
        return `
        <article class="review-task-card${report.status === "done" ? " is-done" : ""}${report.status === "fixed" ? " is-fixed" : ""}${report.status === "metadata" ? " is-metadata" : ""}" data-report-id="${escapeHtml(report.id)}">
          <header>
            <div>
              <small>${escapeHtml(report.articleCategory || report.viewport || "校對回報")}</small>
              ${showArticleTitle ? `<h3>${escapeHtml(report.articleTitle)}</h3>` : ""}
            </div>
            <small>${reportStatusLabel(report.status)}</small>
          </header>
          <p>${escapeHtml(report.comment)}</p>
          ${report.metadataQuote ? `<small>已採用金句：${escapeHtml(report.metadataQuote)}</small>` : ""}
          ${!report.metadataQuote && quoteCandidate ? `<small>可採用為金句：${escapeHtml(quoteCandidate)}</small>` : ""}
          ${report.status === "fixed" ? `<small>已記錄你修過 Word；請先重新執行匯入/重建，頁面預覽更新後再確認無誤。</small>` : ""}
          ${report.screenshot ? `<small>截圖：${escapeHtml(report.screenshot)}</small>` : ""}
          ${report.screenshotDataUrl ? `<img class="review-report-thumb" src="${escapeHtml(report.screenshotDataUrl)}" alt="校對截圖" />` : ""}
          ${compact ? "" : `
            <div class="review-task-card-actions">
              <button type="button" data-report-next="${escapeHtml(report.id)}">${reportPrimaryAction(report.status)}</button>
              ${quoteCandidate ? `<button type="button" data-report-quote="${escapeHtml(report.id)}">採用為網站資料</button>` : ""}
              <button type="button" data-report-remove="${escapeHtml(report.id)}">刪除此回報</button>
            </div>
          `}
        </article>
      `;
      };

      const isCompletedReport = (report) => ["done", "metadata"].includes(report.status);

      const groupedReportsHtml = (reports) => {
        if (!reports.length) return '<p class="review-empty-state">目前沒有修正意見。</p>';
        const knownArticles = new Map((reviewArticleIndex || []).map((article) => [article.slug, article]));
        const groups = new Map();
        reports.forEach((report) => {
          const slug = report.articleSlug || "__unknown";
          if (!groups.has(slug)) {
            const article = knownArticles.get(slug) || {
              slug,
              title: report.articleTitle || "未指定文章",
              category: report.articleCategory || "校對回報"
            };
            groups.set(slug, { ...article, reports: [] });
          }
          groups.get(slug).reports.push(report);
        });

        const orderedGroups = [
          ...(reviewArticleIndex || [])
            .map((article) => groups.get(article.slug))
            .filter(Boolean),
          ...Array.from(groups.values()).filter(
            (group) => !(reviewArticleIndex || []).some((article) => article.slug === group.slug)
          )
        ];

        return orderedGroups
          .map((group) => {
            const total = group.reports.length;
            const openCount = group.reports.filter((report) => !isCompletedReport(report)).length;
            const statusText = openCount ? `${openCount} 待處理 / ${total}` : `已完成 ${total}`;
            return `
              <details class="review-task-group${openCount ? " has-open" : ""}" ${openCount ? "open" : ""}>
                <summary>
                  <span>
                    <small>${escapeHtml(group.category || "校對回報")}</small>
                    <strong>${escapeHtml(group.title)} (${total})</strong>
                  </span>
                  <em>${escapeHtml(statusText)}</em>
                </summary>
                <div class="review-task-group-items">
                  ${group.reports.slice().reverse().map((report) => reportCardHtml(report, false, false)).join("")}
                </div>
              </details>
            `;
          })
          .join("");
      };

      const renderReports = () => {
        const reports = readReports();
        const doneCount = reports.filter(isCompletedReport).length;
        if (reportCountNode) reportCountNode.textContent = String(reports.length);
        if (reportDoneCountNode) reportDoneCountNode.textContent = String(doneCount);

        if (reportBoard) {
          reportBoard.innerHTML = groupedReportsHtml(reports);
        }

        const activeSlug = currentArticle?.slug || liveArticleSelect?.value || "";
        liveReportLists.forEach((list) => {
          const articleReports = reports.filter((report) => report.articleSlug === activeSlug);
          list.innerHTML = articleReports.length
            ? articleReports.slice().reverse().map((report) => reportCardHtml(report, true)).join("")
            : '<p class="review-empty-state">這篇目前沒有回報。</p>';
        });

        if (publishPreviewNode) {
          const payload = buildPublishPayload();
          publishPreviewNode.textContent = JSON.stringify(payload, null, 2);
          if (submitPublishButton) {
            submitPublishButton.disabled = payload.openReports.length > 0;
            submitPublishButton.title = payload.openReports.length
              ? "仍有待處理的修正意見，完成後才能正式發布。"
              : "";
          }
          if (publishStatusNode) {
            const quoteCount = Object.keys(payload.metadataOverrides.quotes).length;
            const tagCount = Object.keys(payload.metadataOverrides.tags).length;
            publishStatusNode.innerHTML = payload.openReports.length
              ? `還有 <strong>${payload.openReports.length}</strong> 則待辦尚未完成；正式發布暫不可送出。`
              : `可進入發布確認：已完成 <strong>${payload.reports.length}</strong> 則待辦，包含 <strong>${quoteCount}</strong> 筆人工金句、<strong>${tagCount}</strong> 筆人工標籤。`;
          }
        }
      };

      const imageFileFromPaste = (event) => {
        const items = Array.from(event.clipboardData?.items || []);
        return items
          .filter((item) => item.type?.startsWith("image/"))
          .map((item) => item.getAsFile())
          .find(Boolean);
      };

      const loadImage = (src) =>
        new Promise((resolve, reject) => {
          const image = new Image();
          image.onload = () => resolve(image);
          image.onerror = reject;
          image.src = src;
        });

      const compressScreenshot = async (file) => {
        const objectUrl = URL.createObjectURL(file);
        try {
          const image = await loadImage(objectUrl);
          const maxWidth = 1200;
          const scale = Math.min(1, maxWidth / image.width);
          const canvas = document.createElement("canvas");
          canvas.width = Math.max(1, Math.round(image.width * scale));
          canvas.height = Math.max(1, Math.round(image.height * scale));
          const context = canvas.getContext("2d");
          context.drawImage(image, 0, 0, canvas.width, canvas.height);
          return canvas.toDataURL("image/jpeg", 0.82);
        } finally {
          URL.revokeObjectURL(objectUrl);
        }
      };

      const setScreenshotOnForm = async (form, file) => {
        if (!form || !file) return;
        const pasteZone = form.querySelector("[data-screenshot-paste]");
        const preview = form.querySelector("[data-screenshot-preview]");
        if (pasteZone) pasteZone.classList.add("is-loading");
        try {
          const dataUrl = await compressScreenshot(file);
          const name = `pasted-screenshot-${new Date().toISOString().replace(/[:.]/g, "-")}.jpg`;
          form.dataset.screenshotName = name;
          form.dataset.screenshotDataUrl = dataUrl;
          if (preview) {
            preview.innerHTML = `<img src="${dataUrl}" alt="已貼上的截圖" /><button type="button" data-clear-screenshot>移除截圖</button>`;
          }
          if (pasteZone) pasteZone.classList.add("has-image");
        } finally {
          if (pasteZone) pasteZone.classList.remove("is-loading");
        }
      };

      const clearScreenshotOnForm = (form) => {
        if (!form) return;
        delete form.dataset.screenshotName;
        delete form.dataset.screenshotDataUrl;
        form.querySelector("[data-screenshot-preview]")?.replaceChildren();
        form.querySelector("[data-screenshot-paste]")?.classList.remove("has-image");
      };

      const activeViewportLabel = () => {
        const active = liveViewportTabs.find((tab) => tab.classList.contains("is-active"));
        return active?.getAttribute("data-live-viewport-tab") === "mobile" ? "手機版" : "電腦版";
      };

      const readApprovals = () => {
        try {
          const parsed = JSON.parse(window.localStorage.getItem(storageKey) || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      };

      const writeApprovals = (approvals) => {
        window.localStorage.setItem(storageKey, JSON.stringify(approvals));
      };

      const cardFieldValue = (card, key) => {
        const input = card.querySelector(`[data-inline-edit] [name="${key}"]`);
        const formValue = input ? String(input.value || "").trim() : "";
        const datasetValue = String(card.dataset[key] || "").trim();
        return formValue || datasetValue;
      };

      const toDecision = (card, decision) => ({
        id: card.dataset.approvalId || "",
        sourceModified: card.dataset.sourceModified || "",
        kind: card.dataset.kind || "import",
        decision,
        issueId: card.dataset.issueId || "",
        title: cardFieldValue(card, "title"),
        category: cardFieldValue(card, "category"),
        author: cardFieldValue(card, "author"),
        date: cardFieldValue(card, "date"),
        file: card.dataset.file || "",
        decidedAt: new Date().toISOString()
      });

      const getCorrections = (form) => {
        const data = new FormData(form);
        return {
          category: String(data.get("category") || "").trim(),
          title: String(data.get("title") || "").trim(),
          author: String(data.get("author") || "").trim(),
          date: String(data.get("date") || "").trim(),
          note: String(data.get("note") || "").trim()
        };
      };

      const approvalPayload = () => ({
        approvals: readApprovals()
          .filter((item) => item.kind === "import" && item.decision === "approved")
          .map(({ kind, decision, issueId, title, category, author, date, file, decidedAt, ...approval }) => approval),
        corrections: readApprovals()
          .filter((item) => item.decision === "corrected")
          .map(({ kind, decision, decidedAt, ...correction }) => correction),
        ignores: readApprovals()
          .filter((item) => item.kind === "import" && item.decision === "ignored")
          .map(({ kind, decision, issueId, title, category, author, date, file, decidedAt, ...ignore }) => ignore),
        fixes: readApprovals()
          .filter((item) => item.decision === "needs-fix")
          .map(({ kind, decision, issueId, title, category, author, date, file, decidedAt, ...fix }) => fix),
        notes: readApprovals().filter((item) => item.kind !== "import")
      });

      const payloadText = () => JSON.stringify(approvalPayload(), null, 2);

      const decisionLabels = {
        approved: "確認可上架",
        corrected: "局部修正",
        ignored: "不需上架／忽略",
        "needs-fix": "需要修正 Word"
      };

      const expectedValue = (item, key) => {
        const corrected = item.corrections?.[key];
        if (corrected) return String(corrected).trim();
        const escapedId = window.CSS?.escape ? CSS.escape(item.id || "") : String(item.id || "").replaceAll('"', '\\"');
        const card = escapedId ? document.querySelector(`[data-approval-id="${escapedId}"]`) : null;
        const cardValue = card ? cardFieldValue(card, key) : "";
        return String(cardValue || item[key] || "").trim() || "未填";
      };

      const renderDecisionSummaryCard = (listNode, item, buttonDatasetName, buttonText) => {
        const li = document.createElement("li");
        const head = document.createElement("div");
        const status = document.createElement("strong");
        const file = document.createElement("span");
        const fields = document.createElement("dl");
        const actions = document.createElement("div");
        const button = document.createElement("button");
        head.className = "review-processed-head";
        fields.className = "review-processed-fields";
        status.textContent = decisionLabels[item.decision] || item.decision || "已處理";
        file.textContent = item.file || item.id || "";
        [
          ["分類", expectedValue(item, "category")],
          ["標題", expectedValue(item, "title")],
          ["作者", expectedValue(item, "author")]
        ].forEach(([label, value]) => {
          const dt = document.createElement("dt");
          const dd = document.createElement("dd");
          dt.textContent = label;
          dd.textContent = value;
          fields.append(dt, dd);
        });
        actions.className = "review-fix-actions";
        button.type = "button";
        button.textContent = buttonText;
        button.dataset[buttonDatasetName] = item.id || "";
        actions.appendChild(button);
        head.append(status, file);
        li.append(head, fields, actions);
        listNode.appendChild(li);
      };

      const markCards = () => {
        const approvals = readApprovals();
        const byId = new Map(approvals.map((item) => [item.id, item]));
        document.querySelectorAll("[data-approval-id]").forEach((card) => {
          const decision = byId.get(card.dataset.approvalId || "")?.decision;
          const isApproved = decision === "approved";
          const isIgnored = decision === "ignored";
          const isCorrected = decision === "corrected";
          card.classList.toggle("status-approved", isApproved);
          card.classList.toggle("status-corrected", isCorrected);
          card.classList.toggle("status-ignored", isIgnored);
          card.classList.toggle("status-needs-fix", decision === "needs-fix");
          if (isApproved) {
            const status = card.querySelector(".review-status");
            if (status) status.textContent = "已確認";
          }
          if (isIgnored) {
            const status = card.querySelector(".review-status");
            if (status) status.textContent = "已忽略";
          }
          card.querySelectorAll("[data-approve-item], [data-ignore-item], [data-edit-item]").forEach((button) => {
            button.disabled = isApproved || isIgnored || isCorrected;
          });
          const approveButton = card.querySelector("[data-approve-item]");
          if (approveButton && isApproved) approveButton.textContent = "已確認";
          const ignoreButton = card.querySelector("[data-ignore-item]");
          if (ignoreButton && isIgnored) ignoreButton.textContent = "已忽略";
        });
      };

      const renderApprovalsLegacy = () => {
        const approvals = readApprovals();
        if (countNode) countNode.textContent = String(approvals.length);
        if (previewNode) previewNode.textContent = payloadText();
        const fixes = approvals.filter((item) => item.decision === "needs-fix");
        if (fixListNode) fixListNode.hidden = fixes.length === 0;
        if (fixListItemsNode) {
          fixListItemsNode.innerHTML = "";
          fixes.forEach((item) => {
            const li = document.createElement("li");
            const title = document.createElement("strong");
            const file = document.createElement("span");
            const actions = document.createElement("div");
            const restoreButton = document.createElement("button");
            title.textContent = item.title || "未命名文章";
            file.textContent = item.file || item.id || "";
            actions.className = "review-fix-actions";
            restoreButton.type = "button";
            restoreButton.textContent = "改為局部修正";
            restoreButton.dataset.restoreFix = item.id || "";
            actions.appendChild(restoreButton);
            li.append(title, file, actions);
            fixListItemsNode.appendChild(li);
          });
        }
        const processed = approvals.filter((item) => item.decision !== "needs-fix");
        if (processedListNode) processedListNode.hidden = processed.length === 0;
        if (processedListItemsNode) {
          processedListItemsNode.innerHTML = "";
          processed
            .slice()
            .reverse()
            .forEach((item) => {
              const li = document.createElement("li");
              const title = document.createElement("strong");
              const meta = document.createElement("span");
              const actions = document.createElement("div");
              const undoButton = document.createElement("button");
              title.textContent = item.corrections?.title || item.title || "未命名文章";
              meta.textContent = `${decisionLabels[item.decision] || item.decision || "已處理"} · ${item.file || item.id || ""}`;
              actions.className = "review-fix-actions";
              undoButton.type = "button";
              undoButton.textContent = "退回重新修正";
              undoButton.dataset.reopenDecision = item.id || "";
              actions.appendChild(undoButton);
              li.append(title, meta, actions);
              processedListItemsNode.appendChild(li);
            });
        }
        if (processedListItemsNode) {
          processedListItemsNode.innerHTML = "";
          processed
            .slice()
            .reverse()
            .forEach((item) => {
              const li = document.createElement("li");
              const head = document.createElement("div");
              const status = document.createElement("strong");
              const file = document.createElement("span");
              const fields = document.createElement("dl");
              const actions = document.createElement("div");
              const undoButton = document.createElement("button");
              head.className = "review-processed-head";
              fields.className = "review-processed-fields";
              status.textContent = decisionLabels[item.decision] || item.decision || "已處理";
              file.textContent = item.file || item.id || "";
              [
                ["分類", expectedValue(item, "category")],
                ["標題", expectedValue(item, "title")],
                ["作者", expectedValue(item, "author")]
              ].forEach(([label, value]) => {
                const dt = document.createElement("dt");
                const dd = document.createElement("dd");
                dt.textContent = label;
                dd.textContent = value;
                fields.append(dt, dd);
              });
              actions.className = "review-fix-actions";
              undoButton.type = "button";
              undoButton.textContent = "退回重新修正";
              undoButton.dataset.reopenDecision = item.id || "";
              actions.appendChild(undoButton);
              head.append(status, file);
              li.append(head, fields, actions);
              processedListItemsNode.appendChild(li);
            });
        }
        markCards();
      };

      const renderApprovals = () => {
        const approvals = readApprovals();
        if (countNode) countNode.textContent = String(approvals.length);
        if (previewNode) previewNode.textContent = payloadText();

        const fixes = approvals.filter((item) => item.decision === "needs-fix");
        if (fixListNode) fixListNode.hidden = fixes.length === 0;
        if (fixListItemsNode) {
          fixListItemsNode.innerHTML = "";
          fixes
            .slice()
            .reverse()
            .forEach((item) => {
              renderDecisionSummaryCard(fixListItemsNode, item, "restoreFix", "改為局部修正");
            });
        }

        const processed = approvals.filter((item) => item.decision !== "needs-fix");
        if (processedListNode) processedListNode.hidden = processed.length === 0;
        if (processedListItemsNode) {
          processedListItemsNode.innerHTML = "";
          processed
            .slice()
            .reverse()
            .forEach((item) => {
              renderDecisionSummaryCard(processedListItemsNode, item, "reopenDecision", "退回重新修正");
            });
        }

        markCards();
      };

      const reopenForCorrection = (id) => {
        if (!id) return;
        const approvals = readApprovals();
        const next = approvals.filter((item) => item.id !== id);
        writeApprovals(next);
        renderApprovals();
        const escapedId = window.CSS?.escape ? CSS.escape(id) : id.replaceAll('"', '\\"');
        const card = document.querySelector(`[data-approval-id="${escapedId}"]`);
        if (!card) return;
        card.classList.remove("status-approved", "status-corrected", "status-ignored", "status-needs-fix");
        card.querySelectorAll("[data-approve-item], [data-ignore-item], [data-edit-item], [data-fix-item]").forEach((button) => {
          button.disabled = false;
        });
        const form = card.querySelector("[data-inline-edit]");
        if (form) form.hidden = false;
        card.scrollIntoView({ behavior: "smooth", block: "center" });
      };

      const decideCard = (card, decision) => {
        const record = toDecision(card, decision);
        if (!record.id) return;
        const approvals = readApprovals();
        const next = approvals.filter((item) => item.id !== record.id);
        next.push(record);
        writeApprovals(next);
        renderApprovals();
      };

      const approveCard = (card) => decideCard(card, "approved");

      const ignoreCard = (card) => decideCard(card, "ignored");

      const fixCard = (card) => decideCard(card, "needs-fix");

      const correctCard = (card, form) => {
        const record = {
          ...toDecision(card, "corrected"),
          corrections: getCorrections(form)
        };
        if (!record.id) return;
        const approvals = readApprovals();
        const next = approvals.filter((item) => item.id !== record.id);
        next.push(record);
        writeApprovals(next);
        renderApprovals();
      };

      document.querySelectorAll("[data-approve-item]").forEach((button) => {
        button.addEventListener("click", () => {
          const card = button.closest("[data-approval-id]");
          if (card) approveCard(card);
        });
      });

      document.querySelectorAll("[data-ignore-item]").forEach((button) => {
        button.addEventListener("click", () => {
          const card = button.closest("[data-approval-id]");
          if (card) ignoreCard(card);
        });
      });

      document.querySelectorAll("[data-edit-item]").forEach((button) => {
        button.addEventListener("click", () => {
          const card = button.closest("[data-approval-id]");
          const form = card?.querySelector("[data-inline-edit]");
          if (form) form.hidden = !form.hidden;
        });
      });

      document.querySelectorAll("[data-inline-edit]").forEach((form) => {
        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const card = form.closest("[data-approval-id]");
          if (card) correctCard(card, form);
        });
      });

      document.querySelectorAll("[data-cancel-edit]").forEach((button) => {
        button.addEventListener("click", () => {
          const form = button.closest("[data-inline-edit]");
          if (form) form.hidden = true;
        });
      });

      document.querySelectorAll("[data-fix-item]").forEach((button) => {
        button.addEventListener("click", () => {
          const card = button.closest("[data-approval-id]");
          if (!card) return;
          card.classList.add("status-needs-fix");
          const status = card.querySelector(".review-status");
          if (status) status.textContent = "需修正 Word";
          button.textContent = "已標記需修正";
          button.disabled = true;
        });
      });

      document.querySelectorAll("[data-fix-item]").forEach((button) => {
        button.addEventListener("click", () => {
          const card = button.closest("[data-approval-id]");
          if (card) fixCard(card);
        });
      });

      fixListItemsNode?.addEventListener("click", (event) => {
        const button = event.target.closest("[data-restore-fix]");
        if (!button) return;
        reopenForCorrection(button.dataset.restoreFix || "");
      });

      processedListItemsNode?.addEventListener("click", (event) => {
        const button = event.target.closest("[data-reopen-decision]");
        if (!button) return;
        reopenForCorrection(button.dataset.reopenDecision || "");
      });

      downloadButton?.addEventListener("click", () => {
        const blob = new Blob([payloadText()], { type: "application/json;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = "review-approvals.json";
        link.click();
        URL.revokeObjectURL(url);
      });

      saveButton?.addEventListener("click", async () => {
        const picker = window.showSaveFilePicker;
        if (!picker) {
          downloadButton?.dispatchEvent(new Event("click"));
          return;
        }
        const handle = await picker({
          suggestedName: "review-approvals.json",
          types: [{ description: "JSON", accept: { "application/json": [".json"] } }]
        });
        const writable = await handle.createWritable();
        await writable.write(payloadText());
        await writable.close();
      });

      copyButton?.addEventListener("click", async () => {
        await navigator.clipboard.writeText(payloadText());
      });

      clearButton?.addEventListener("click", () => {
        writeApprovals([]);
        document.querySelectorAll("[data-approve-item]").forEach((button) => {
          button.textContent = "確認可上架";
          button.disabled = false;
        });
        document.querySelectorAll("[data-ignore-item]").forEach((button) => {
          button.textContent = "不需上架／忽略";
          button.disabled = false;
        });
        document.querySelectorAll("[data-fix-item]").forEach((button) => {
          button.textContent = "需要修正 Word";
          button.disabled = false;
        });
        document.querySelectorAll("[data-edit-item]").forEach((button) => {
          button.disabled = false;
        });
        document.querySelectorAll("[data-inline-edit]").forEach((form) => {
          form.hidden = true;
        });
        document.querySelectorAll("[data-approval-id]").forEach((card) => {
          card.classList.remove("status-approved");
          card.classList.remove("status-corrected");
          card.classList.remove("status-ignored");
          card.classList.remove("status-needs-fix");
        });
        renderApprovals();
      });

      const modeTabs = Array.from(document.querySelectorAll("[data-review-mode-tab]"));
      const modePanels = Array.from(document.querySelectorAll("[data-review-mode-panel]"));
      modeTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-review-mode-tab");
          modeTabs.forEach((item) => item.classList.toggle("is-active", item === tab));
          modePanels.forEach((panel) => {
            panel.classList.toggle("is-active", panel.getAttribute("data-review-mode-panel") === target);
          });
        });
      });

      liveArticleSelect?.addEventListener("change", () => {
        syncLiveArticle(liveArticleSelect.value);
      });

      liveViewportTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          syncLiveViewport(tab.getAttribute("data-live-viewport-tab") || "desktop");
          window.setTimeout(resizeLiveFrames, 80);
        });
      });

      liveFrames.forEach((frame) => {
        frame.addEventListener("load", () => {
          try {
            const frameSlug = slugFromArticleUrl(frame.contentWindow?.location?.href || frame.src);
            if (frameSlug && frameSlug !== (liveArticleSelect?.value || "")) {
              syncSelectedArticle(frameSlug);
              renderReports();
            }
          } catch {
            // Same-origin article frames should sync; ignore browser edge cases.
          }
          resizeLiveFrame(frame);
          window.setTimeout(() => resizeLiveFrame(frame), 250);
        });
      });

      window.addEventListener("resize", resizeLiveFrames);

      document.querySelectorAll("[data-report-form]").forEach((form) => {
        form.addEventListener("paste", async (event) => {
          const imageFile = imageFileFromPaste(event);
          if (!imageFile) return;
          event.preventDefault();
          await setScreenshotOnForm(form, imageFile);
        });

        form.addEventListener("click", (event) => {
          if (event.target.closest("[data-clear-screenshot]")) {
            clearScreenshotOnForm(form);
          }
        });

        form.addEventListener("submit", (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const selectedArticle = currentArticle?.slug
            ? currentArticle
            : articleFromOption(selectedArticleOption(liveArticleSelect));
          const selectedSlug = selectedArticle.slug;
          if (!selectedSlug) {
            const result = form.querySelector("[data-report-result]");
            if (result) result.textContent = "文章尚未載入完成";
            return;
          }
          const screenshot = form.dataset.screenshotName || "";
          const report = {
            id: `${Date.now()}-${Math.random().toString(16).slice(2)}`,
            articleSlug: selectedArticle.slug,
            articleTitle: selectedArticle.title,
            articleCategory: selectedArticle.category,
            articleAuthor: selectedArticle.author,
            articleUrl: selectedArticle.url,
            viewport: String(formData.get("viewport") || activeViewportLabel()).trim(),
            comment: String(formData.get("comment") || "").trim(),
            screenshot,
            screenshotDataUrl: form.dataset.screenshotDataUrl || "",
            status: "open",
            createdAt: new Date().toISOString()
          };
          if (!report.comment) return;
          const reports = readReports();
          reports.push(report);
          writeReports(reports);
          form.reset();
          clearScreenshotOnForm(form);
          syncLiveArticle(selectedSlug);
          const result = form.querySelector("[data-report-result]");
          if (result) {
            result.textContent = "已加入待辦清單";
            window.setTimeout(() => {
              result.textContent = "";
            }, 2400);
          }
          renderReports();
        });
      });

      reportBoard?.addEventListener("click", (event) => {
        const nextButton = event.target.closest("[data-report-next]");
        const removeButton = event.target.closest("[data-report-remove]");
        const quoteButton = event.target.closest("[data-report-quote]");
        if (!nextButton && !removeButton && !quoteButton) return;
        const id =
          nextButton?.dataset.reportNext ||
          removeButton?.dataset.reportRemove ||
          quoteButton?.dataset.reportQuote ||
          "";
        const reports = readReports();
        const next = removeButton
          ? reports.filter((report) => report.id !== id)
          : reports.map((report) =>
              report.id === id
                ? quoteButton
                  ? {
                      ...report,
                      status: "metadata",
                      metadataQuote: extractMetadataQuote(report.comment),
                      metadataUpdatedAt: new Date().toISOString()
                    }
                  : {
                      ...report,
                      status:
                        report.status === "open"
                          ? "fixed"
                          : report.status === "fixed" || report.status === "metadata"
                            ? "done"
                            : "open"
                    }
                : report
            );
        writeReports(next);
        renderReports();
      });

      submitPublishButton?.addEventListener("click", async () => {
        const payload = buildPublishPayload();
        if (payload.openReports.length) {
          if (publishStatusNode) {
            publishStatusNode.innerHTML = `還有 <strong>${payload.openReports.length}</strong> 則待辦尚未完成；完成後才能正式發布。`;
          }
          return;
        }

        if (!publishWebhookUrl) {
          if (publishStatusNode) {
            publishStatusNode.textContent = "尚未設定正式發布中介。請先部署 Google Apps Script，並設定 PUBLIC_REVIEW_PUBLISH_WEBHOOK_URL。";
          }
          return;
        }

        submitPublishButton.disabled = true;
        const originalText = submitPublishButton.textContent;
        submitPublishButton.textContent = "送出中...";
        if (publishStatusNode) publishStatusNode.textContent = "正在送出正式發布請求...";

        try {
          await fetch(publishWebhookUrl, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "text/plain" },
            body: JSON.stringify(payload)
          });

          if (publishStatusNode) {
            publishStatusNode.innerHTML = `已送出正式發布請求。請到 <a href="${deployWorkflowUrl}" target="_blank" rel="noreferrer">GitHub Actions</a> 查看部署進度。`;
          }
        } catch (error) {
          if (publishStatusNode) {
            publishStatusNode.textContent = "\u91cd\u65b0\u532f\u5165\u5931\u6557\uff1a" + (error.message || error);
          }
        } finally {
          submitPublishButton.disabled = false;
          submitPublishButton.textContent = originalText;
        }
      });


      submitReimportButton?.addEventListener("click", async () => {
        if (!publishWebhookUrl) {
          if (publishStatusNode) {
            publishStatusNode.textContent = "\u5c1a\u672a\u8a2d\u5b9a\u91cd\u65b0\u532f\u5165\u4e2d\u4ecb\u3002\u8acb\u5148\u90e8\u7f72 Google Apps Script\uff0c\u4e26\u8a2d\u5b9a PUBLIC_REVIEW_PUBLISH_WEBHOOK_URL\u3002";
          }
          return;
        }

        const requestStartedAt = new Date();
        let previousRunId = "";
        const refreshUrl = `${window.location.pathname}${window.location.search || ""}`;
        submitReimportButton.disabled = true;
        const originalText = submitReimportButton.textContent;
        submitReimportButton.textContent = "\u532f\u5165\u4e2d...";
        if (publishStatusNode) {
          publishStatusNode.innerHTML = '<span class="review-progress-dot"></span>\u6b63\u5728\u9001\u51fa\u91cd\u65b0\u532f\u5165\u8acb\u6c42...';
        }

        try {
          try {
            previousRunId = String((await latestWorkflowRun())?.id || "");
          } catch {
            previousRunId = "";
          }

          await fetch(publishWebhookUrl, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "text/plain" },
            body: JSON.stringify({
              action: "reimport",
              issueId: "latest",
              runAi: false,
              requestedAt: new Date().toISOString()
            })
          });

          if (publishStatusNode) {
            publishStatusNode.innerHTML = `<span class="review-progress-dot"></span>\u5df2\u9001\u51fa\u91cd\u65b0\u532f\u5165\u8acb\u6c42\uff0c\u6b63\u5728\u7b49\u5f85 GitHub Actions \u958b\u59cb... <a href="${deployWorkflowUrl}" target="_blank" rel="noreferrer">\u67e5\u770b\u9032\u5ea6</a>`;
          }

          try {
            const run = await pollReimportWorkflow({ previousRunId, startedAt: requestStartedAt });
            if (publishStatusNode && run?.status === "completed" && run.conclusion === "success") {
              const wasSkipped = await syncDriveStepWasSkipped(run);
              if (wasSkipped) {
                publishStatusNode.innerHTML = `\u672c\u6b21\u5efa\u7f6e\u5df2\u5b8c\u6210\uff0c\u4f46 <strong>Sync Google Drive source</strong> \u88ab\u7565\u904e\uff0c\u4ee3\u8868\u6c92\u6709\u91cd\u65b0\u540c\u6b65 Word\u3002\u8acb\u6aa2\u67e5 Google Apps Script reimport \u662f\u5426\u9001\u51fa <code>sync_drive=true</code>\u3002 <a href="${run.html_url}" target="_blank" rel="noreferrer">\u67e5\u770b\u4f5c\u696d</a>`;
              } else {
                publishStatusNode.innerHTML = `\u91cd\u65b0\u532f\u5165\u5df2\u5b8c\u6210\u3002<a href="${refreshUrl}">\u91cd\u65b0\u6574\u7406\u672c\u9801</a>\u5f8c\uff0c\u5c31\u6703\u770b\u5230\u6700\u65b0 Word \u9810\u89bd\u3002`;
              }
            } else if (publishStatusNode && run?.status === "completed") {
              publishStatusNode.innerHTML = `\u91cd\u65b0\u532f\u5165\u6c92\u6709\u6210\u529f\u3002\u8acb\u5230 <a href="${run.html_url || deployWorkflowUrl}" target="_blank" rel="noreferrer">GitHub Actions</a> \u67e5\u770b\u5931\u6557\u539f\u56e0\u3002`;
            } else if (publishStatusNode) {
              publishStatusNode.innerHTML = `\u5df2\u9001\u51fa\u91cd\u65b0\u532f\u5165\u8acb\u6c42\uff0c\u4f46\u672a\u80fd\u81ea\u52d5\u78ba\u8a8d\u4f5c\u696d\u5b8c\u6210\u3002\u8acb\u5230 <a href="${deployWorkflowUrl}" target="_blank" rel="noreferrer">GitHub Actions</a> \u78ba\u8a8d\uff1b\u82e5\u986f\u793a\u7da0\u8272\u6210\u529f\uff0c\u5c31\u53ef\u4ee5 <a href="${refreshUrl}">\u91cd\u65b0\u6574\u7406\u672c\u9801</a>\u3002`;
            }
          } catch {
            if (publishStatusNode) {
              publishStatusNode.innerHTML = `\u5df2\u9001\u51fa\u91cd\u65b0\u532f\u5165\u8acb\u6c42\uff0c\u4f46\u700f\u89bd\u5668\u7121\u6cd5\u81ea\u52d5\u8b80\u53d6 GitHub Actions \u72c0\u614b\u3002\u8acb\u7a0d\u5019 1-3 \u5206\u9418\u5f8c\u91cd\u65b0\u6574\u7406\uff0c\u6216\u5230 <a href="${deployWorkflowUrl}" target="_blank" rel="noreferrer">GitHub Actions</a> \u67e5\u770b\u9032\u5ea6\u3002`;
            }
          }
        } catch (error) {
          if (publishStatusNode) {
            publishStatusNode.textContent = "\u91cd\u65b0\u532f\u5165\u5931\u6557\uff1a" + (error.message || error);
          }
        } finally {
          submitReimportButton.disabled = false;
          submitReimportButton.textContent = originalText;
        }
      });

      clearReportsButton?.addEventListener("click", () => {
        writeReports([]);
        renderReports();
      });

      const mobileReviewQuery = window.matchMedia("(max-width: 680px)");
      const applyMobileReviewMode = () => {
        if (mobileReviewQuery.matches) syncLiveViewport("mobile");
      };

      syncLiveArticle(liveArticleSelect?.value || "");
      syncLiveViewport(mobileReviewQuery.matches ? "mobile" : "desktop");
      mobileReviewQuery.addEventListener?.("change", applyMobileReviewMode);
      renderReports();
      renderApprovals();
      window.setTimeout(resizeLiveFrames, 250);
    </script>
  </body>
</html>





